{
  "name": "@omlet/webapp",
  "private": true,
  "version": "1.0.0",
  "description": "Analytics interface of Omlet",
  "repository": "https://github.com/zeplin/omlet",
  "homepage": "https://github.com/zeplin/omlet",
  "bugs": "https://github.com/zeplin/omlet/issues",
  "author": "Zeplin",
  "license": "MIT",
  "keywords": [
    "analytics",
    "react",
    "component",
    "front-end",
    "ui",
    "statistics",
    "UI components",
    "design systems",
    "component library"
  ],
  "scripts": {
    "dev": "npm run create-env && npm run docker:infra && concurrently \"npm run dev:be\" \"npm run dev:fe\"",
    "debug": "concurrently \"npm run debug:be\" \"npm run dev:fe\"",
    "dev:fe": "vite",
    "dev:be": "npm run migrations:up && ts-node-dev --project tsconfig.backend.json --respawn --transpile-only src/backend/server.ts",
    "debug:be": "ts-node-dev --project tsconfig.backend.json --inspect --respawn --transpile-only src/backend/server.ts",
    "build:be": "tsc --project tsconfig.backend.json",
    "build:fe": "vite build",
    "lint": "eslint ./src ./tests --ext .js,.jsx,.ts,.tsx",
    "lint:staged": "lint-staged",
    "preview": "vite preview",
    "start": "node dist/backend/server.js",
    "test": "npm run create-test-env && jest",
    "clean": "rm -rf dist",
    "docker": "docker compose -f docker-compose.yml --project-name omlet",
    "docker:up": "npm run migrations:up && npm run docker -- up -d",
    "docker:down": "npm run docker -- down",
    "docker:infra": "npm run docker -- up -d omlet_mongodb omlet_redis",
    "migrations:list": "migrate-mongo status",
    "migrations:create": "migrate-mongo create -f ./db-migrations/migrate-mongo-config.js",
    "migrations:up": "migrate-mongo up -f ./db-migrations/migrate-mongo-config.js",
    "migrations:down": "migrate-mongo down -f ./db-migrations/migrate-mongo-config.js",
    "omlet:analyze": "omlet analyze -i 'src/frontend/**/*.{tsx,ts,js,jsx}'",
    "prepare": "([ -n \"$CI\" ] && exit 0) || (cd .. && husky install)",
    "create-env": "ts-node-dev --project tsconfig.backend.json --transpile-only create-env.ts",
    "create-test-env": "ts-node-dev --project tsconfig.backend.json --transpile-only create-test-env.ts"
  },
  "dependencies": {
    "@octokit/auth-oauth-user": "^4.1.0",
    "@octokit/core": "^3.6.0",
    "cli-spinners": "^2.7.0",
    "compression": "^1.7.4",
    "content-type": "^1.0.5",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.0",
    "emoji-regex": "^10.3.0",
    "etag": "^1.8.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "google-auth-library": "^7.14.1",
    "http-status-codes": "^2.2.0",
    "http-terminator": "^3.2.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.3",
    "lz-string": "^1.5.0",
    "millify": "^6.1.0",
    "mongo-cursor-pagination": "^7.6.1",
    "mongoose": "^7.8.7",
    "ms": "^2.1.3",
    "nanoid": "^3.3.2",
    "node-fetch": "^2.6.7",
    "outdent": "^0.8.0",
    "react-router-dom": "^6.27.0",
    "redlock": "^4.2.0",
    "slugify": "^1.6.5",
    "unicode-emoji-json": "^0.6.0"
  },
  "devDependencies": {
    "@nivo/core": "^0.80.0",
    "@nivo/line": "^0.80.0",
    "@nivo/stream": "^0.80.0",
    "@omlet/cli": "^2.2.0",
    "@stylistic/eslint-plugin": "^3.1.0",
    "@tanstack/eslint-plugin-query": "^5.59.7",
    "@tanstack/react-query": "^5.59.15",
    "@types/compression": "^1.7.3",
    "@types/content-type": "^1.1.8",
    "@types/cookie-parser": "^1.4.2",
    "@types/eslint": "^8.37.0",
    "@types/etag": "^1.8.1",
    "@types/express": "^5.0.5",
    "@types/jest": "^27.4.1",
    "@types/js-cookie": "^3.0.1",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^16.11.68",
    "@types/node-fetch": "^2.6.2",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@types/redlock": "^4.0.4",
    "@types/superagent": "^4.1.15",
    "@types/supertest": "^2.0.11",
    "@types/youtube": "^0.0.48",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.13.0",
    "@vitejs/plugin-react": "^1.0.7",
    "classnames": "^2.3.1",
    "cli-progress": "^3.11.2",
    "concurrently": "^6.3.0",
    "email-validator": "^2.0.4",
    "emoji-type": "^1.0.4",
    "eslint": "^8.10.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "js-cookie": "^3.0.1",
    "lint-staged": "^13.3.0",
    "localforage": "^1.10.0",
    "migrate-mongo": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.9.4",
    "stylelint": "^15.6.1",
    "superagent": "^7.1.1",
    "supertest": "^6.2.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^1.1.8",
    "typescript": "~4.5.5",
    "unplugin-fonts": "^1.0.3",
    "vite": "^2.8.0",
    "vite-plugin-checker": "^0.6.0"
  },
  "overrides": {
    "mongoose": {
      "mongodb": "5.9.2",
      "bson": "5.5.1"
    },
    "mongo-cursor-pagination": {
      "mongodb": "5.9.2",
      "bson": "5.5.1"
    }
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx}": "eslint --fix --max-warnings 0",
    "tests/**/*.{js,ts,tsx}": "eslint --fix --max-warnings 0"
  }
}
