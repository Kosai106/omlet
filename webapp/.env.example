# production (used for production and staging), development (for local development)
NODE_ENV=

### These are private variables to be used only on the server side

# These are used for signing JWT tokens (used in tests, base64 encoded)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

# HTTP port to be used for Node.js middleware to listen to
MW_PORT=

# A flag to enable emails
EMAILS_ENABLED=

# URI string for MongoDB connection
MONGODB_URI=

# A flag to enable debug mode for Mongoose (default: false)
MONGODB_DEBUG_ENABLED=

# URI string for Redis connection
REDIS_URI=

# Base URL of the web app
APP_BASE_URL=

# Client ID of the Google app (used for Google Sign-in)
GOOGLE_CLIENT_ID=

# Client ID of the Google app
GOOGLE_CLIENT_SECRET=

# Client ID of the Github OAuth app (used for Github Sign-in)
GITHUB_CLIENT_ID=

# Client ID of the Github OAuth app
GITHUB_CLIENT_SECRET=

# "production", "staging", or "local" (default: "local")
APP_ENV=

# Enable response compression in the Express app
RESPONSE_COMPRESSION_ENABLED=

# Flag to enable static file serving using Express.js (disabled by default)
USE_STATIC_MIDDLEWARE=

### All variables used in the frontend app should start with `VITE_`.
### These variables should be defined in Vite specific env files (.env.production, .env.staging, .env.development)

# Base URL of the web app
VITE_APP_BASE_URL=

# Base URL of the landing paage
VITE_LANDING_PAGE_BASE_URL=

# Disable checker plugin in local dev server
VITE_CHECKER_DISABLED=

# A flag to enable emails
VITE_EMAILS_ENABLED=

### Feature flags
