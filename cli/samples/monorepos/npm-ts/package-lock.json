{
  "name": "root",
  "lockfileVersion": 2,
  "requires": true,
  "packages": {
    "": {
      "name": "root",
      "workspaces": [
        "ds",
        "app"
      ]
    },
    "app": {
      "version": "1.0.0",
      "license": "ISC",
      "dependencies": {
        "ds": "^1.0.0"
      },
      "devDependencies": {}
    },
    "ds": {
      "version": "1.0.0",
      "license": "ISC"
    },
    "node_modules/app": {
      "resolved": "app",
      "link": true
    },
    "node_modules/ds": {
      "resolved": "ds",
      "link": true
    }
  },
  "dependencies": {
    "app": {
      "version": "file:app",
      "requires": {
        "ds": "*"
      }
    },
    "ds": {
      "version": "file:ds"
    }
  }
}
