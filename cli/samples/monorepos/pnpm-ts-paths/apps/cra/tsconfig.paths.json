{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@nighttrax/components/*": [
        "../../packages/components/src/*"
      ],
      "@nighttrax/page-components": [
        "../../packages/components/src/pageComponents.tsx"
      ],
      "@nighttrax/styled-components": [
        "../../packages/components/src/styled/index.ts"
      ],
      "@nighttrax/components": [
        "../../packages/components/src/index.ts"
      ],
      "@nighttrax/*": [
