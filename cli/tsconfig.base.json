{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "lib": [
      "es2018"
    ],
    "allowJs": true,
    "declaration": true,
    "sourceMap": false,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "./node_modules/@types/",
      "./ts-typings/"
    ],
    "paths": {
      "get-tsconfig": [
        "./node_modules/get-tsconfig/dist/index.cjs"
      ]
    }
  }
}
